.env
*.pem
*.key
azure_credentials.json

# ── IDE ───────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp

# ── OS ────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

