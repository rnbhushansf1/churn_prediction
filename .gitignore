*.pkl
*.joblib

# ── Python ────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
dist/
build/
.eggs/
*.egg

# ── Virtual environments ──────────────────────────────────────────────────
.venv/
venv/
env/
.env

